# Dokploy env for Payload CMS service
# Service port inside container
PORT=3000
NODE_ENV=production

# Public URLs
PAYLOAD_PUBLIC_SERVER_URL=https://cms.example.com
NEXT_PUBLIC_SERVER_URL=https://cms.example.com
NEXT_PUBLIC_FRONTEND_URL=https://frontend.example.com
FRONTEND_URL=https://frontend.example.com
PUBLIC_API_URL=https://api.example.com/api
SITE_URL=https://frontend.example.com

# Payload / Postgres
PAYLOAD_SECRET=replace_with_long_random_secret
# Use your Dokploy Postgres external/internal connection string.
DATABASE_URL=postgresql://user:password@postgres-host:5432/dbname
DATABASE_URI=postgresql://user:password@postgres-host:5432/dbname
# UAT/dev only: auto sync Payload tables/fields on start. For real prod, use migrations instead.
PAYLOAD_DB_PUSH=true

# CORS / CSRF
CORS_ORIGINS=https://frontend.example.com,https://api.example.com,http://localhost:5173
CSRF_ORIGINS=https://frontend.example.com,https://api.example.com,http://localhost:5173

# Internal cleanup token used by CMS hook to call its own cleanup endpoint
CMS_INTERNAL_URL=https://cms.example.com
CMS_INTERNAL_CLEANUP_TOKEN=replace_with_random_internal_token
ADMIN_INTERNAL_TOKEN=replace_with_random_internal_token

# Cloudflare R2 media storage
R2_ENABLED=true
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ENDPOINT=https://your_cloudflare_account_id.r2.cloudflarestorage.com
R2_BUCKET=your_bucket_name
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_PUBLIC_URL=https://media.example.com
R2_REGION=auto
# Optional if your bucket uses a folder prefix
# R2_KEY_PREFIX=estela

# Optional upload caps. Empty means use App Config values.
# MAX_IMAGE_UPLOAD_MB=10
# MAX_VIDEO_UPLOAD_MB=100

# Health / restart tuning
WAIT_TIMEOUT_MS=120000
CMS_HEALTH_CHECK_TIMEOUT_MS=2500
CMS_HEALTH_TOTAL_TIMEOUT_MS=7000
