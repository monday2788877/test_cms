# Payload CMS standalone deploy on Railway
# Copy these variables into Railway service variables.

# Required
DATABASE_URL=postgresql://neondb_owner:<PASSWORD>@ep-divine-butterfly-aqgorcfi-pooler.c-8.us-east-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URI=postgresql://neondb_owner:<PASSWORD>@ep-divine-butterfly-aqgorcfi-pooler.c-8.us-east-1.aws.neon.tech/neondb?sslmode=require
DIRECT_URL=postgresql://neondb_owner:<PASSWORD>@ep-divine-butterfly-aqgorcfi.c-8.us-east-1.aws.neon.tech/neondb?sslmode=require
PAYLOAD_SECRET=change-me-to-a-long-random-secret

# Railway provides PORT automatically. Keep this only for local tests if needed.
PORT=3000
NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1

# Public URLs
PAYLOAD_PUBLIC_SERVER_URL=https://your-payload-service.up.railway.app
NEXT_PUBLIC_SERVER_URL=https://your-payload-service.up.railway.app
FRONTEND_URL=https://uat-agreement.tpbs.com.vn
PUBLIC_API_PUBLIC_URL=https://api-uat-agreement.tpbs.com.vn
KONG_PUBLIC_URL=https://uat-agreement.tpbs.com.vn

# CORS / CSRF origins, comma-separated if used by your gateway setup.
CORS_ORIGINS=https://uat-agreement.tpbs.com.vn,https://api-uat-agreement.tpbs.com.vn,https://your-payload-service.up.railway.app
CSRF_ORIGINS=https://uat-agreement.tpbs.com.vn,https://api-uat-agreement.tpbs.com.vn,https://your-payload-service.up.railway.app

# Bootstrap schema for local/UAT. For strict production, set false and use Payload migrations.
PAYLOAD_SCHEMA_PUSH_ON_START=true
WAIT_TIMEOUT_MS=180000

# Upload limits
MAX_IMAGE_UPLOAD_MB=8
MAX_VIDEO_UPLOAD_MB=80

# Cloudflare R2 storage. For production, set R2_ENABLED=true and fill all values.
# Upload uses R2_ENDPOINT. Public reads should use R2_PUBLIC_URL, ideally a custom domain.
R2_ENABLED=true
R2_ACCOUNT_ID=<CLOUDFLARE_ACCOUNT_ID>
R2_ACCESS_KEY_ID=<R2_ACCESS_KEY_ID>
R2_SECRET_ACCESS_KEY=<R2_SECRET_ACCESS_KEY>
R2_BUCKET=real-estate-media
R2_REGION=auto
R2_ENDPOINT=https://<CLOUDFLARE_ACCOUNT_ID>.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://media-uat-agreement.tpbs.com.vn

# Optional: used by Payload hooks to call Public API search sync, if enabled.
PUBLIC_API_INTERNAL_URL=
ADMIN_INTERNAL_TOKEN=change-me-admin-token

# R2 demo seed behavior
# true = seed:r2 deletes and re-uploads only r2-demo-* media files each run.
R2_REUPLOAD_EXISTING=true
